#include <stdio.h>

int main() {
    int n, i, time = 0, completed = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int pid[n], at[n], bt[n], rt[n], wt[n], tat[n];
    float avg_wt = 0, avg_tat = 0;
    for(i = 0; i < n; i++) {
        pid[i] = i + 1;
        printf("\nProcess %d\n", pid[i]);
        printf("Arrival Time: ");
        scanf("%d", &at[i]);
        printf("Burst Time: ");
        scanf("%d", &bt[i]);
        rt[i] = bt[i];
    }
    while(completed < n) {
        int min_index = -1;
        int min_rt = 9999;
        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0) {
                if(rt[i] < min_rt) {
                    min_rt = rt[i];
                    min_index = i;
                }
            }
        }

        if(min_index == -1) {
            time++;
        }
        else {
            rt[min_index]--;
            time++;
            if(rt[min_index] == 0) {
                completed++;

                int finish_time = time;
                tat[min_index] = finish_time - at[min_index];
                wt[min_index] = tat[min_index] - bt[min_index];

                avg_wt += wt[min_index];
                avg_tat += tat[min_index];
            }
        }
    }
    printf("\nProcess\tAT\tBT\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\n",
               pid[i], at[i], bt[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat/n);

    return 0;
}
