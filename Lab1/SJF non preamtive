#include <stdio.h>

int main() {
    int n, i, j, time = 0, completed = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int pid[n], at[n], bt[n], wt[n], tat[n], done[n];
    float avg_wt = 0, avg_tat = 0;

    // Input
    for(i = 0; i < n; i++) {
        pid[i] = i + 1;
        printf("\nProcess %d\n", pid[i]);
        printf("Arrival Time: ");
        scanf("%d", &at[i]);
        printf("Burst Time: ");
        scanf("%d", &bt[i]);
        done[i] = 0;   // Not completed
    }


    printf("\nProcess\tAT\tBT\tWT\tTAT\n");

    while(completed < n) {
        int min_index = -1;
        int min_bt = 9999;

        // Find shortest job among arrived processes
        for(i = 0; i < n; i++) {
            if(at[i] <= time && done[i] == 0) {
                if(bt[i] < min_bt) {
                    min_bt = bt[i];
                    min_index = i;
                }
            }
        }

        if(min_index == -1) {
            time++;   // CPU idle
        }
        else {
            wt[min_index] = time - at[min_index];
            time += bt[min_index];
            tat[min_index] = wt[min_index] + bt[min_index];

            done[min_index] = 1;
            completed++;

            avg_wt += wt[min_index];
            avg_tat += tat[min_index];

            printf("P%d\t%d\t%d\t%d\t%d\n",
                   pid[min_index],
                   at[min_index],
                   bt[min_index],
                   wt[min_index],
                   tat[min_index]);
        }
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat/n);

    return 0;
}
